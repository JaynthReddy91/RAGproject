# LLM Provider Configuration (options: gemini, openai, xai, grok, ollama)
LLM_PROVIDER=gemini

# API Keys (Provide at least the one corresponding to LLM_PROVIDER)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
XAI_API_KEY=your_grok_api_key_here

# Model Selection
# For OpenAI: gpt-4o-mini, gpt-4
# For Gemini: gemini-1.5-flash, gemini-1.5-pro
# For Grok: grok-2-1212, grok-beta
# For Ollama: gemma2:2b, llama3
LLM_MODEL=gemini-1.5-flash

# Embeddings (options: local, openai)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Re-ranking (options: local, none)
RERANKER_PROVIDER=local
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Storage & Retrieval Settings
CHROMA_DB_PATH=./chroma_db
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=10
TOP_K_RERANK=4
